{
  "name": "immipulse-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --import tsx src/server.ts",
    "broker": "node --import tsx src/notifications/broker.ts",
    "dev": "node --import tsx --watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@node-rs/argon2": "^2.0.2",
    "fastify": "^4.28.1",
    "nodemailer": "^6.9.14",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.4",
    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
