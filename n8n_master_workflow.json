{
  "name": "ImmiPulse RSS Poll Master",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "value": 4
            }
          ]
        }
      },
      "id": "e2f073fa-850d-40c2-9e90-c26685f4039f",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        380,
        240
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, name, url FROM rss_sources WHERE is_active = true;",
        "options": {}
      },
      "id": "f516a8fa-71f0-46eb-b70d-c011e4bf51a2",
      "name": "Get Active Sources",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        600,
        240
      ],
      "credentials": {
        "postgres": {
          "id": "YOUR_POSTGRES_CREDENTIALS_ID",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "mode": "each",
        "workflowId": "YOUR_SUB_WORKFLOW_ID",
        "options": {
          "waitForSubworkflow": false
        }
      },
      "id": "c62ef4a5-3a0c-4fa2-938b-d516ca238a0f",
      "name": "Execute Sub-workflow",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1.1,
      "position": [
        820,
        240
      ],
      "onError": "continueRegularOutput"
    }
  ],
  "pinData": {},
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Get Active Sources",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Active Sources": {
      "main": [
        [
          {
            "node": "Execute Sub-workflow",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1",
    "binaryMode": "separate"
  },
  "versionId": "YOUR_VERSION_ID",
  "meta": {
    "templateCredsSetupCompleted": true,
    "instanceId": "YOUR_INSTANCE_ID"
  },
  "id": "YOUR_MASTER_WORKFLOW_ID",
  "tags": []
}
