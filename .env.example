# =============================================================
# ImmiPulse Environment Variables
# Copy to .env and fill in real values before deploying.
# =============================================================

# Database
DB_USER=yutian
DB_PASSWORD=change_me_to_a_strong_password
DATABASE_URL=postgresql://yutian:change_me@postgres:5432/immipulse

# LLM API configuration (Anthropic-compatible API endpoint)
LLM_API_KEY=your_llm_api_key_here
LLM_API_URL=your_llm_api_url_here
LLM_MODEL=your_llm_model_here

# Dashboard Authentication
DASHBOARD_API_TOKEN=generate_a_secure_random_token

# Cloudflare Tunnel
TUNNEL_TOKEN=your_cloudflare_tunnel_token

# Data Retention
NEWS_RETENTION_DAYS=90

# CORS (Comma-separated list of allowed frontend domains for cross-origin requests)
CORS_ORIGINS=https://your-frontend-domain1.com,https://your-frontend-domain2.com

# =============================================================
# Frontend Build Variables
# These variables will automatically be picked up by Next.js
# from this root .env file during `npm run build`.
# =============================================================

# The public URL where your backend is hosted (via Cloudflare Tunnel)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api

# Must match DASHBOARD_API_TOKEN above
NEXT_PUBLIC_DASHBOARD_API_TOKEN=generate_a_secure_random_token
