    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  sub.id AS dup_id, \n  sub.distance,\n  $2::text AS link,\n  $3::text AS title,\n  $4::text AS \"contentSnippet\",\n  $5::text AS \"pubDate\",\n  $6::text AS id,\n  $7::json AS vector\nFROM (\n  SELECT id, title_vector <-> $1::vector AS distance \n  FROM news_items \n  ORDER BY title_vector <-> $1::vector \n  LIMIT 1\n) AS sub \nUNION ALL \nSELECT \n  NULL AS dup_id, \n  999.0 AS distance,\n  $2::text AS link,\n  $3::text AS title,\n  $4::text AS \"contentSnippet\",\n  $5::text AS \"pubDate\",\n  $6::text AS id,\n  $7::json AS vector\nLIMIT 1;",
        "options": {
          "queryReplacement": "={{ [\n  JSON.stringify($json.data), \n  $json.link, \n  $json.title, \n  $json.contentSnippet || '', \n  $json.pubDate || '', \n  $json.id, \n  JSON.stringify($json.data)\n] }}"
        }
