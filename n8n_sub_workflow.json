        "query": "INSERT INTO news_items (\n  title_original, title_en, title_zh, \n  summary_original, summary_en, summary_zh, \n  original_language, source_name, source_url, published_at, \n  parent_id, \n  importance_score, video_score, chinese_relevance_score, evergreen_score\n) VALUES (\n  $1, 'duplicate', 'duplicate', 'duplicate', 'duplicate', 'duplicate', \n  'en', $2, $3, $4, \n  $5, \n  0, 0, 0, 0\n);",
        "options": {
          "queryReplacement": "={{ [ \n  $json.title,\n  $('Workflow Trigger').item.json.name,\n  $json.link, \n  $json.pubDate, \n  $json.id \n] }}"
        }
      },
