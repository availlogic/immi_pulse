    {
      "parameters": {
        "method": "POST",
        "url": "https://api.minimaxi.com/anthropic/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Api-Key",
              "value": "={{$env.MINIMAX_API_KEY}}"
