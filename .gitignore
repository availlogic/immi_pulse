# =============================================================
# ImmiPulse .gitignore
# =============================================================

# ---- OS / IDE ----
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Secrets ----
.env
.env.*
!.env.example
*.pem
*.key
cloudflared-credentials.json

# ---- Python ----
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ---- uv ----
.uv-cache/

# ---- Node.js & Frontend ----
node_modules/
.next/
out/
build/
dist/
*.tsbuildinfo
.vercel/
.wrangler/
.cloudflare/
/.pnp*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---- Testing ----
coverage/
test-results/
playwright-report/

# ---- Docker ----
pgdata/

# ---- Logs ----
logs/
*.log

# ---- AI Agent ----
.agents/

# ---- Local Databases ----
*.sqlite
*.sqlite3
*.db
